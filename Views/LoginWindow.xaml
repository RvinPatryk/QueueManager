<Window x:Class="QueueManager.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logowanie - Queue Manager"
        Height="500"
        Width="500"
        MinHeight="500"
        MinWidth="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">
        <Border Background="White"
                Margin="32"
                Padding="28"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Queue Manager"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1"
                           Text="Zaloguj się do systemu"
                           Foreground="#666666"
                           Margin="0,0,0,24"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Login"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox x:Name="UsernameTextBox"
                             Height="34"
                             Padding="8"
                             Margin="0,0,0,14"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Hasło"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Height="34"
                                 Padding="8"
                                 Margin="0,0,0,10"/>
                </StackPanel>

                <TextBlock Grid.Row="4"
                           x:Name="ErrorTextBlock"
                           Foreground="#C62828"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"
                           Margin="0,4,0,0"/>

                <Button Grid.Row="5"
                        Content="Zaloguj"
                        Height="38"
                        Click="LoginButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>