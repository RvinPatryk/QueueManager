<Window x:Class="QueueManager.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Queue Manager - Rejestracja"
        Height="560"
        Width="500"
        MinHeight="560"
        MinWidth="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#F9FAFB"/>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F5F5">
        <Border Background="{StaticResource CardBrush}"
                Margin="32"
                Padding="30"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Utwórz konto"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextMainBrush}"
                           Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1"
                           Text="Nowe konto otrzyma rolę zwykłego użytkownika."
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="14"
                           Margin="0,0,0,24"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Nazwa użytkownika"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMainBrush}"
                               Margin="0,0,0,6"/>

                    <TextBox x:Name="UsernameTextBox"
                             Margin="0,0,0,16"/>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <TextBlock Text="Hasło"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMainBrush}"
                               Margin="0,0,0,6"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,0,0,16"/>
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="Powtórz hasło"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMainBrush}"
                               Margin="0,0,0,6"/>

                    <PasswordBox x:Name="RepeatPasswordBox"
                                 Margin="0,0,0,8"/>
                </StackPanel>

                <TextBlock Grid.Row="5"
                           x:Name="ErrorTextBlock"
                           Foreground="#C62828"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"
                           Margin="0,4,0,0"/>

                <Grid Grid.Row="6"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Utwórz konto"
                            Click="RegisterButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>

                    <Button Grid.Column="2"
                            Content="Anuluj"
                            Click="CancelButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>