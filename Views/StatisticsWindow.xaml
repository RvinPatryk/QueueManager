<Window x:Class="QueueManager.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Queue Manager - Statystyki"
        Height="760"
        Width="1200"
        MinHeight="600"
        MinWidth="900"
        Background="#F5F5F5"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#F9FAFB"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="76"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">

            <Grid Margin="28,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Statystyki zadań"
                               FontSize="24"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Podsumowanie statusów, przypisań oraz priorytetów."
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Zamknij"
                        Click="CloseButton_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        
        

        <!-- Content -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="24">
                <UniformGrid Columns="3" Margin="0,0,0,16">
                    <Border Background="#F8FAFC"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Zadania z czasem"
                            Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding CompletedTasksWithDurationCount}"
                            FontSize="22"
                            FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8FAFC"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12"
            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Łączny czas realizacji"
                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding TotalActualTime}"
                       FontSize="22"
                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F8FAFC"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
                        <StackPanel>
                            <TextBlock Text="Średni czas realizacji"
                       Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding AverageActualTime}"
                       FontSize="22"
                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Statusy -->
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="20"
                        Margin="0,0,0,16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Zadania według statusu"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Liczba zadań w poszczególnych etapach realizacji."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding StatusSeries}"
                                            XAxes="{Binding StatusXAxes}"
                                            Height="250"/>
                    </Grid>
                </Border>

                <!-- Użytkownicy -->
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="20"
                        Margin="0,0,0,16">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Zadania przypisane do użytkowników"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Najbardziej obciążeni użytkownicy na podstawie liczby przypisanych zadań."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding AssignedUsersSeries}"
                                            XAxes="{Binding AssignedUsersXAxes}"
                                            Height="250"/>
                    </Grid>
                </Border>

                <!-- Priorytety -->
                <Border Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="20">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Rozkład priorytetów"
                                       FontSize="20"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Liczba zadań dla każdego poziomu priorytetu od 1 do 10."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <lvc:CartesianChart Grid.Row="1"
                                            Series="{Binding PrioritySeries}"
                                            XAxes="{Binding PriorityXAxes}"
                                            Height="250"/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>