<Window x:Class="QueueManager.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logi systemu"
        Height="500"
        Width="850"
        MinHeight="350"
        MinWidth="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Logi systemu"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBox Grid.Row="1"
                 x:Name="LogsTextBox"
                 IsReadOnly="True"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="13"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">

            <Button Content="Zamknij"
                    Width="100"
                    Height="32"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>